# ============================================================
#  UGC Otomasyon — Ortam Degiskenleri
#  Bu dosyayi .env.local olarak kopyalayip degerleri doldurun.
#  .env.local ASLA git'e commit edilmez (.gitignore'da).
# ============================================================

# --- fal.ai ---
# https://fal.ai/dashboard/keys adresinden alin
FAL_KEY=

# --- OpenRouter (persona + senaryo uretimi) ---
# https://openrouter.ai/keys adresinden alin
OPENROUTER_API_KEY=
# NOT: Modeller workflow ile ayni sekilde kodda sabittir
#   persona -> google/gemini-2.0-flash-001
#   senaryo -> google/gemini-2.5-pro
# (degistirmek icin lib/prompts.ts > PERSONA_MODEL / SCRIPTS_MODEL)

# --- Google Drive (OAuth - kendi hesabiniz) ---
# Google Cloud Console > OAuth 2.0 Client (Web/Desktop) bilgileri
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# `npm run get-google-token` ile bir kez alinan refresh token
GOOGLE_REFRESH_TOKEN=
# Videolarin yuklenecegi Drive klasor ID'si (klasor URL'sindeki son parca)
GDRIVE_FOLDER_ID=

# --- Gmail SMTP (e-posta bildirimi) ---
# Gmail hesabi + uygulama sifresi (App Password, 16 hane)
GMAIL_USER=
GMAIL_APP_PASSWORD=
# Bildirimlerin gonderilecegi varsayilan alici (form bos birakilirsa)
NOTIFY_EMAIL=

# --- Uygulama ---
# Yerelde http://localhost:3000 ; Vercel'de canli URL
APP_URL=http://localhost:3000
